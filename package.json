{
  "name": "rizhi",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "postinstall": "node ./scripts/ensure-uni-hbuilder-deps.mjs",
    "dev": "npm run dev:unicloud --workspace=@rizhi/web",
    "dev:web": "npm run dev:unicloud --workspace=@rizhi/web",
    "dev:uni": "npm run dev:h5 --workspace=@rizhi/uni-app",
    "dev:unicloud": "npm run dev:unicloud --workspace=@rizhi/web",
    "dev:test": "npm run dev:test --workspace=@rizhi/web",
    "build": "npm run build --workspace=@rizhi/web",
    "build:web": "npm run build --workspace=@rizhi/web",
    "build:unicloud": "npm run build:unicloud --workspace=@rizhi/web",
    "build:test": "npm run build:test --workspace=@rizhi/web",
    "build:production": "npm run build:production --workspace=@rizhi/web",
    "deploy:web:test": "node ./scripts/deploy-web.mjs staging",
    "deploy:web:production": "node ./scripts/deploy-web.mjs production",
    "build:uni": "npm run build:h5 --workspace=@rizhi/uni-app",
    "build:all": "npm run build && npm run build:uni",
    "preview": "npm run preview --workspace=@rizhi/web",
    "test": "npm run test --workspace=@rizhi/web",
    "test:e2e": "node ./scripts/run-e2e.mjs",
    "typecheck": "npm run typecheck --workspace=@rizhi/web",
    "typecheck:web": "npm run typecheck --workspace=@rizhi/web",
    "typecheck:uni": "npm run type-check --workspace=@rizhi/uni-app",
    "typecheck:all": "npm run typecheck && npm run typecheck:uni"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^26.0.1",
    "typescript": "^5.7.2"
  }
}
