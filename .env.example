VITE_DATA_SOURCE=indexeddb
VITE_API_BASE_URL=http://127.0.0.1:8787/api/v1
# Fastify backend:
# VITE_DATA_SOURCE=http
# VITE_API_BASE_URL=http://127.0.0.1:8797/api/v1

# Fastify SQLite database path (defaults to .data/rizhi-api.db)
# RIZHI_API_SQLITE_PATH=./.data/rizhi-api.db

# Production API
RIZHI_FASTIFY_HOST=127.0.0.1
RIZHI_FASTIFY_PORT=8797
# Set a long random value before exposing the API outside localhost.
# RIZHI_API_TOKEN=replace-with-a-long-random-secret

# Scheduled SQLite backups
RIZHI_BACKUP_INTERVAL_HOURS=24
RIZHI_BACKUP_RETENTION_COUNT=14
# RIZHI_BACKUP_DIRECTORY=./.data/backups
