{
  "name": "@rizhi/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:unicloud": "vite --mode unicloud",
    "dev:test": "vite --mode staging",
    "build": "vue-tsc -b && vite build",
    "build:unicloud": "vue-tsc -b && vite build --mode unicloud",
    "build:test": "vue-tsc -b && vite build --mode staging",
    "build:production": "vue-tsc -b && vite build --mode production",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "typecheck": "vue-tsc -b"
  },
  "dependencies": {
    "@lucide/vue": "^1.17.0",
    "dexie": "^4.0.11",
    "echarts": "^5.6.0",
    "naive-ui": "^2.40.3",
    "pinia": "^2.3.0",
    "vue": "^3.5.13",
    "vue-echarts": "^7.0.3",
    "vue-router": "^4.5.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.0.1",
    "@vitejs/plugin-vue": "^5.2.1",
    "fake-indexeddb": "^6.2.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^4.1.9",
    "vue-tsc": "^2.2.0"
  }
}
